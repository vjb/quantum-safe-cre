{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "local-cre-sdk", "**/*.test.ts"]
}
